<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="TechMartPU" transaction-type="JTA">
        <!-- GlassFish: jdbc/TechMartDS | WildFly: java:/jdbc/TechMartDS -->
        <jta-data-source>jdbc/TechMartDS</jta-data-source>

        <class>com.techmart.entity.Product</class>
        <class>com.techmart.entity.Customer</class>
        <class>com.techmart.entity.Order</class>
        <class>com.techmart.entity.OrderItem</class>

        <properties>
            <property name="eclipselink.ddl-generation" value="create-or-extend-tables"/>
            <property name="eclipselink.logging.level" value="WARNING"/>
            <property name="hibernate.jdbc.batch_size" value="25"/>
        </properties>
    </persistence-unit>
</persistence>
